  {
    "id": "c_increment",
    "language": "cpp",
    "category": "operators",
    "version": "1.0.0",
    "blockDef": {
      "type": "c_increment",
      "message0": "變數 %1 %2",
      "args0": [
        { "type": "field_input", "name": "NAME", "text": "i" },
        { "type": "field_dropdown", "name": "OP", "options": [["加 1（++）","++"],["減 1（--）","--"]] }
      ],
      "output": "Expression",
      "colour": 210,
      "tooltip": "讓變數的值加 1 或減 1"
    },
    "codeTemplate": {
      "pattern": "${NAME}${OP}",
      "imports": [],
      "order": 8
    },
    "astPattern": {
      "nodeType": "update_expression",
      "constraints": []
    }
  },
  {
    "id": "c_compound_assign",
    "language": "cpp",
    "category": "operators",
    "version": "1.0.0",
    "blockDef": {
      "type": "c_compound_assign",
      "message0": "把變數 %1 %2 %3",
      "args0": [
        { "type": "field_input", "name": "NAME", "text": "x" },
        { "type": "field_dropdown", "name": "OP", "options": [["加上（+=）","+="],["減去（-=）","-="],["乘以（*=）","*="],["除以（/=）","/="],["取餘數（%=）","%="]] },
        { "type": "input_value", "name": "VALUE", "check": "Expression" }
      ],
      "previousStatement": "Statement",
      "nextStatement": "Statement",
      "colour": 210,
      "tooltip": "把變數的值加上、減去、乘以、除以或取餘數後存回去"
    },
    "codeTemplate": {
      "pattern": "${NAME} ${OP} ${VALUE};",
      "imports": [],
      "order": 0
    },
    "astPattern": {
      "nodeType": "assignment_expression",
      "constraints": []
    }
  },
  {
    "id": "c_switch",
    "language": "cpp",
    "category": "conditions",
    "version": "1.0.0",
    "blockDef": {
      "type": "c_switch",
      "message0": "根據 %1 的值",
      "args0": [
        { "type": "input_value", "name": "EXPR", "check": "Expression" }
      ],
      "message1": "%1",
      "args1": [
        { "type": "input_statement", "name": "CASES", "check": "Statement" }
      ],
      "previousStatement": "Statement",
      "nextStatement": "Statement",
      "colour": 40,
      "tooltip": "根據一個值來決定要執行哪一段程式，類似多個「如果」的快捷寫法"
    },
    "codeTemplate": {
      "pattern": "switch (${EXPR}) {\n${CASES}\n}",
      "imports": [],
      "order": 0
    },
    "astPattern": {
      "nodeType": "switch_statement",
      "constraints": []
    }
  },
  {
    "id": "c_case",
    "language": "cpp",
    "category": "conditions",
    "version": "1.0.0",
    "blockDef": {
      "type": "c_case",
      "message0": "當值為 %1 :",
      "args0": [
        { "type": "input_value", "name": "VALUE", "check": "Expression" }
      ],
      "message1": "%1",
      "args1": [
        { "type": "input_statement", "name": "BODY", "check": "Statement" }
      ],
      "previousStatement": "Statement",
      "nextStatement": "Statement",
      "colour": 40,
      "tooltip": "當上面的值等於這個值時，就執行這段程式"
    },
    "codeTemplate": {
      "pattern": "case ${VALUE}:\n${BODY}",
      "imports": [],
      "order": 0
    },
    "astPattern": {
      "nodeType": "case_statement",
      "constraints": []
    }
  },
  {
    "id": "c_for_loop",
    "language": "cpp",
    "category": "loops",
    "version": "1.0.0",
    "blockDef": {
      "type": "c_for_loop",
      "message0": "自訂重複：初始 %1 ；條件 %2 ；更新 %3",
      "args0": [
        { "type": "input_value", "name": "INIT", "check": "Expression" },
        { "type": "input_value", "name": "COND", "check": "Expression" },
        { "type": "input_value", "name": "UPDATE", "check": "Expression" }
      ],
      "message1": "執行 %1",
      "args1": [
        { "type": "input_statement", "name": "BODY", "check": "Statement" }
      ],
      "previousStatement": "Statement",
      "nextStatement": "Statement",
      "colour": 120,
      "tooltip": "自訂的重複迴圈：先設定初始值，每次檢查條件，通過就執行，然後更新"
    },
    "codeTemplate": {
      "pattern": "for (${INIT}; ${COND}; ${UPDATE}) {\n${BODY}\n}",
      "imports": [],
      "order": 0
    },
    "astPattern": {
      "nodeType": "for_statement",
      "constraints": []
    }
  },
  {
    "id": "c_do_while",
    "language": "cpp",
    "category": "loops",
    "version": "1.0.0",
    "blockDef": {
      "type": "c_do_while",
      "message0": "先執行 %1",
      "args0": [
        { "type": "input_statement", "name": "BODY", "check": "Statement" }
      ],
      "message1": "當 %1 繼續重複",
      "args1": [
        { "type": "input_value", "name": "COND", "check": "Expression" }
      ],
      "previousStatement": "Statement",
      "nextStatement": "Statement",
      "colour": 120,
      "tooltip": "先執行一次裡面的程式，然後檢查條件，成立就繼續重複"
    },
    "codeTemplate": {
      "pattern": "do {\n${BODY}\n} while (${COND});",
      "imports": [],
      "order": 0
    },
    "astPattern": {
      "nodeType": "do_statement",
      "constraints": []
    }
  },
  {
    "id": "c_printf",
    "language": "cpp",
    "category": "io",
    "version": "1.0.0",
    "blockDef": {
      "type": "c_printf",
      "message0": "格式輸出 \" %1 \" %2",
      "args0": [
        { "type": "field_input", "name": "FORMAT", "text": "%d\\n" },
        { "type": "field_input", "name": "ARGS", "text": ", x" }
      ],
      "previousStatement": "Statement",
      "nextStatement": "Statement",
      "colour": 180,
      "tooltip": "用格式字串輸出內容。常用格式：%d 整數、%f 小數、%s 文字、\\n 換行"
    },
    "codeTemplate": {
      "pattern": "printf(\"${FORMAT}\"${ARGS});",
      "imports": ["stdio.h"],
      "order": 0
    },
    "astPattern": {
      "nodeType": "call_expression",
      "constraints": [{ "field": "function", "text": "printf" }]
    }
  },
  {
    "id": "c_scanf",
    "language": "cpp",
    "category": "io",
    "version": "1.0.0",
    "blockDef": {
      "type": "c_scanf",
      "message0": "格式輸入 \" %1 \" %2",
      "args0": [
        { "type": "field_input", "name": "FORMAT", "text": "%d" },
        { "type": "field_input", "name": "ARGS", "text": ", &x" }
      ],
      "previousStatement": "Statement",
      "nextStatement": "Statement",
      "colour": 180,
      "tooltip": "用格式字串讀取輸入。變數前要加 &（取址符號），如 &x"
    },
    "codeTemplate": {
      "pattern": "scanf(\"${FORMAT}\"${ARGS});",
      "imports": ["stdio.h"],
      "order": 0
    },
    "astPattern": {
      "nodeType": "call_expression",
      "constraints": [{ "field": "function", "text": "scanf" }]
    }
  }
